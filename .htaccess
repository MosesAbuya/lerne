<IfModule mod_rewrite.c>
    RewriteEngine On

    # SEO Slugs for News and Events
    RewriteRule ^news/([^/]+)/?$ blog_details.php?slug=$1 [L,QSA]
    RewriteRule ^events/([^/]+)/?$ event_details.php?slug=$1 [L,QSA]

    # Remove .php extension
    # If the requested URI is not a directory or file
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    # And if the corresponding .php file exists
    RewriteCond %{REQUEST_FILENAME}.php -f
    # Rewrite to the .php file
    RewriteRule ^([^\.]+)$ $1.php [NC,L]
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On

    # Cache images
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Cache fonts
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"

    # Cache CSS and JS files
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Cache static assets
    <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|woff|woff2|ttf|otf|css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML files cache control
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=300"
    </FilesMatch>

    # CORS for Fonts
    <FilesMatch "\.(woff|woff2|ttf|otf)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>

    # Security Headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# Protect .htaccess file
<Files .htaccess>
    order allow,deny
    deny from all
</Files>

# Increase PHP upload limits
<IfModule mod_php.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value max_file_uploads 50
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value max_file_uploads 50
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value max_file_uploads 50
</IfModule>
